{
  "name": "aegis",
  "version": "7.0.3",
  "description": "AEGIS — Feature Complete Desktop Client for the OpenClaw Gateway",
  "main": "dist-electron/main.js",
  "author": "Rashed",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pdromnt/openclaw-aegis.git"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"vite\" \"wait-on http://localhost:5173 && node scripts/build-electron.js && electron . --enable-logging\"",
    "dev:web": "vite",
    "build:electron": "node scripts/build-electron.js",
    "build:renderer": "vite build",
    "build": "node scripts/build-electron.js && vite build",
    "package:win": "npm run build && electron-builder --win",
    "package:portable:win": "npm run build && electron-builder --win portable",
    "package:mac": "npm run build && electron-builder --mac",
    "package:mac:dmg": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@tailwindcss/postcss": "^4.2.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.4",
    "emoji-picker-react": "^4.19.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.8",
    "lodash": "^4.18.1",
    "lucide-react": "^1.14.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-is": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "react-syntax-highlighter": "^16.1.1",
    "react-virtuoso": "^4.18.6",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.4.0",
    "electron-builder": "^26.9.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.aegis.desktop",
    "productName": "AEGIS",
    "copyright": "Copyright © 2026 Rashed",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools",
      "artifactName": "AEGIS-${version}-macOS-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "AEGIS",
      "menuCategory": "AEGIS",
      "perMachine": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerSidebar": null,
      "artifactName": "AEGIS-Setup-${version}.${ext}",
      "unicode": true,
      "include": "installer/nsis-script.nsh",
      "installerLanguages": [
        "en_US",
        "ar_SA"
      ]
    },
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "!assets/*.png"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      },
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "fileAssociations": [],
    "protocols": [
      {
        "name": "AEGIS Protocol",
        "schemes": [
          "aegis"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "pdromnt",
        "repo": "openclaw-aegis"
      }
    ],
    "npmRebuild": false
  },
  "overrides": {
    "yauzl": "3.3.0"
  }
}
